DATABASE_URL="postgresql://postgres:postgres@localhost:5432/my_project_database?schema=public"
SHADOW_DATABASE_URL="postgresql://postgres:postgres@localhost:5432/my_project_database_shadow?schema=public"

API_PORT=3001
FRONTEND_ORIGIN=http://localhost:3000
# Used by the Nest API to sign and verify JWT access tokens.
JWT_SECRET="replace-with-a-long-random-secret-min-32-chars"
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_DAYS=7

NEXT_PUBLIC_API_URL=http://localhost:3001/api
NEXT_PUBLIC_YANDEX_MAPS_API_KEY=
YANDEX_GEOCODER_API_KEY=

# First public release toggle. Keep disabled until subscription flows are ready for users.
NEXT_PUBLIC_SUBSCRIPTIONS_ENABLED=false
SUBSCRIPTIONS_ENABLED=false

# Telegram Bot API integration. Operational admin notifications go to the shared chat below.
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=White_Box_Loyalty_bot

TELEGRAM_ADMIN_CHAT_ID=3977200071
# Public HTTPS URL opened by Telegram bot Web App buttons.
TELEGRAM_WEB_APP_URL=https://whitebox-web-production.up.railway.app/
# Max accepted age for Telegram Mini App initData during passwordless login.
TELEGRAM_MINI_APP_AUTH_MAX_AGE_SECONDS=86400
# Optional local proxy for Telegram Bot API, for example http://127.0.0.1:10809
TELEGRAM_PROXY_URL=
# Public HTTPS endpoint for button callbacks, for example https://whitebox.app/api/telegram/webhook
TELEGRAM_WEBHOOK_URL=
# Local dev endpoint used by npm run telegram:poll:local.
TELEGRAM_LOCAL_WEBHOOK_URL=http://localhost:3000/api/telegram/webhook
# Local polling safe mode. Keep enabled to avoid reading/responding to group chats
# or random comments while developing with a dev bot.
TELEGRAM_LOCAL_POLL_PRIVATE_ONLY=true
TELEGRAM_LOCAL_POLL_COMMANDS_ONLY=true
# Optional secret header checked by /api/telegram/webhook.
TELEGRAM_WEBHOOK_SECRET=
# Optional secret for /api/admin/reports/daily GET preview and POST delivery.
DAILY_REPORT_SECRET=

# Temporary encrypted storage for company verification passport photos.
# Keep this secret stable: changing it makes existing encrypted files unreadable.
# If empty, the app falls back to JWT_SECRET in local/dev environments.
PASSPORT_STORAGE_SECRET="replace-with-a-long-random-secret-min-32-chars"
PASSPORT_STORAGE_DIR="storage/private/passport-verifications"

# YooKassa payment acceptance. Keep the secret key only in env/secrets.
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=
YOOKASSA_RETURN_URL=http://localhost:3000/payment/success
YOOKASSA_COMPANY_RETURN_URL=http://localhost:3000/company/billing
# VAT code used in YooKassa receipt items. 1 = without VAT.
YOOKASSA_VAT_CODE=1
# Maximum bank-card checkout/subscription price in RUB.
YOOKASSA_MAX_BANK_CARD_PAYMENT_RUB=349999

# Email transport. Without SMTP_HOST the API stores messages in DB and logs them as a dev outbox.
MAIL_FROM="NearLoy <no-reply@nearloy.local>"
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=

# Optional smart email routing.
# Russian recipient domains (yandex.ru, mail.ru, bk.ru, etc.) use YANDEX_SMTP_* when configured.
# Gmail/international recipient domains use GOOGLE_SMTP_* when configured.
GOOGLE_SMTP_HOST=smtp.gmail.com
GOOGLE_SMTP_PORT=465
GOOGLE_SMTP_SECURE=true
GOOGLE_SMTP_USER=
GOOGLE_SMTP_PASS=
GOOGLE_SMTP_FROM=
YANDEX_SMTP_HOST=smtp.yandex.ru
YANDEX_SMTP_PORT=465
YANDEX_SMTP_SECURE=true
YANDEX_SMTP_USER=
YANDEX_SMTP_PASS=
YANDEX_SMTP_FROM=

REGISTRATION_EMAIL_CODE_TTL_MINUTES=15
EMAIL_CHANGE_TOKEN_HOURS=24
