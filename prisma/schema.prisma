// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum SubscriptionStatus {
  ACTIVE
  EXPIRED
  CANCELED
}

/// Application role: TWA loyalty app users are CLIENT; company portals & admin consoles use COMPANY / admin roles.
enum UserRole {
  CLIENT
  COMPANY
  ADMIN
  SUPER_ADMIN
  MANAGER
  SUPPORT
}

enum AccountStatus {
  ACTIVE
  FROZEN_PENDING_DELETION
  BLOCKED
}

enum ProfileStatusRarity {
  RARE
  EPIC
  LEGENDARY
}

enum LoyaltyTransactionType {
  EARN
  SPEND
}

enum LoyaltyTransactionStatus {
  ACTIVE
  EXPIRED
}

enum SubscriptionSpendPolicy {
  EXCLUDE
  INCLUDE_NO_BONUS
  INCLUDE_WITH_BONUS
}

enum CompanyMemberRole {
  OWNER
  MANAGER
  CASHIER
}

enum SubscriptionEntitlementWindow {
  DAY
  WEEK
  MONTH
  TERM
  UNLIMITED
}

enum AuditWorkspace {
  MANAGER
  DEVELOPER
}

enum AuditLevel {
  INFO
  WARN
  CRITICAL
}

enum AuditCategory {
  SECURITY
  USER
  SUBSCRIPTION
  BILLING
  SYSTEM
}

enum AuditResult {
  SUCCESS
  BLOCKED
}

enum AdminTaskSource {
  AUDIT
  COMPANY_VERIFICATION
  FINANCE
}

enum AdminTaskPriority {
  NORMAL
  HIGH
  CRITICAL
}

enum AdminTaskStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  DISMISSED
}

enum LandingLeadStatus {
  NEW
  IN_PROGRESS
  CLOSED
  SPAM
}

enum NotificationDeliveryStatus {
  PENDING
  SENT
  FAILED
}

enum CompanyEmploymentType {
  SELF_EMPLOYED
  INDIVIDUAL_ENTREPRENEUR
}

enum CompanyVerificationStatus {
  DRAFT
  SUBMITTED
  REVIEWING
  APPROVED
  REJECTED
}

enum IdentityVerificationMode {
  FULL
  DEFERRED
}

enum PassportFileStatus {
  ACTIVE
  DELETED
  MISSING
}

enum CompanyKycAccessAction {
  UPSERT_FROM_VERIFICATION
  REVEAL_DATA
  VIEW_PHOTO
  DELETE_PHOTO
}

enum PromoCodeRewardType {
  POINTS
  SUBSCRIPTION
}

enum SubscriptionBundleStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

enum SubscriptionBundleParticipantStatus {
  PENDING
  APPROVED
  REJECTED
}

enum ReferralInviteStatus {
  CREATED
  REDEEMED
  REWARDED
}

enum CompanyReferralStatus {
  ACTIVE
  PAUSED
  ENDED
}

enum CompanyReferralPipelineStatus {
  LEAD
  NEGOTIATION
  TRIAL
  CONNECTED
  REVENUE_ACTIVE
  LOST
}

enum PermissionScope {
  USERS
  COMPANIES
  COMPANY_VERIFICATIONS
  PR
  FINANCE
  SUPPORT
  AUDIT
  DATABASE
  TELEGRAM
  SETTINGS
}

enum FinanceOperationType {
  PAYOUT_REQUEST
  PAYOUT_APPROVAL
  MANUAL_ADJUSTMENT
  REFUND
}

enum FinanceOperationStatus {
  DRAFT
  PENDING_APPROVAL
  APPROVED
  REJECTED
  PAID
  CANCELED
}

enum CompanyBillingStatus {
  TRIAL
  ACTIVE
  PAST_DUE
  SUSPENDED
}

enum CompanyBillingInvoiceStatus {
  OPEN
  PAID
  WAIVED
  CANCELED
}

enum PaymentProvider {
  YOOKASSA
}

enum PaymentPurpose {
  USER_SUBSCRIPTION
  USER_SUBSCRIPTION_BUNDLE
}

enum PaymentStatus {
  PENDING
  WAITING_FOR_CAPTURE
  SUCCEEDED
  CANCELED
  FAILED
  REFUNDED
}

enum EmailMessageStatus {
  PENDING
  SENT
  FAILED
}

enum EmailMessageTargetType {
  USER
  COMPANY
  DIRECT
}

enum EmailVerificationPurpose {
  REGISTRATION
}

enum EmailVerificationStatus {
  PENDING
  CONSUMED
  EXPIRED
}

model User {
  id              Int                @id @default(autoincrement())
  uuid            String             @unique @default(uuid())
  telegramId      BigInt?            @unique
  phoneNumber     String?            @unique
  phoneVerifiedAt DateTime?
  companyReferralCode String?        @unique
  name            String
  email           String             @unique
  role            UserRole           @default(CLIENT)
  /// bcrypt hash; null for Telegram-only or OAuth-only users until password is set
  passwordHash    String?
  emailVerifiedAt DateTime?
  accountStatus         AccountStatus @default(ACTIVE)
  deletionScheduledAt   DateTime?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  companyLinks  UserCompany[]
  subscriptions UserSubscription[]
  subscriptionBundles UserSubscriptionBundle[]
  refreshTokens RefreshToken[]
  oauthAccounts OAuthAccount[]
  favoriteCategories UserFavoriteCategory[]
  emailChangeRequests EmailChangeRequest[] @relation("EmailChangeTarget")
  requestedEmailChanges EmailChangeRequest[] @relation("EmailChangeRequester")
  managedCompany Company? @relation("CompanyOwner")
  companyMemberships CompanyMember[]
  companyPurchases CompanyPurchase[] @relation("CompanyPurchaseCustomer")
  processedCompanyPurchases CompanyPurchase[] @relation("CompanyPurchaseProcessor")
  processedSubscriptionRedemptions SubscriptionRedemption[] @relation("SubscriptionRedemptionProcessor")
  processedSubscriptionBundleRedemptions SubscriptionBundleRedemption[] @relation("SubscriptionBundleRedemptionProcessor")
  loginEvents LoginEvent[]
  loyaltyTransactions LoyaltyTransaction[]
  actorAuditEvents AuditEvent[] @relation("AuditActor")
  targetAuditEvents AuditEvent[] @relation("AuditTarget")
  profilePreference UserProfilePreference?
  promoRedemptions PromoCodeRedemption[]
  referralInvites ReferralInvite[] @relation("ReferralInviter")
  redeemedReferralInvites ReferralInvite[] @relation("ReferralInvited")
  companyReferrals CompanyReferral[] @relation("CompanyReferralOwner")
  supportedCompanies Company[] @relation("CompanySupportManager")
  telegramLinkTokens TelegramLinkToken[]
  customerLookupCodes CustomerLookupCode[]
  permissions AdminUserPermission[]
  selectedProfileStatusId String?
  selectedProfileStatus ProfileStatus? @relation("SelectedProfileStatus", fields: [selectedProfileStatusId], references: [id], onDelete: SetNull)
  profileStatusUnlocks UserProfileStatusUnlock[] @relation("UserProfileStatusUnlocks")
  grantedProfileStatuses UserProfileStatusUnlock[] @relation("ProfileStatusUnlockedBy")
  requestedFinanceOperations FinanceOperation[] @relation("FinanceRequestedBy")
  approvedFinanceOperations FinanceOperation[] @relation("FinanceApprovedBy")
  assignedAdminTasks AdminTask[] @relation("AdminTaskAssignee")
  resolvedAdminTasks AdminTask[] @relation("AdminTaskResolver")
  proposedSubscriptionBundles SubscriptionBundle[] @relation("SubscriptionBundleProposer")
  approvedSubscriptionBundleParticipants SubscriptionBundleParticipant[] @relation("SubscriptionBundleParticipantApprover")
  createdCompanyBillingPromoCodes CompanyBillingPromoCode[] @relation("CompanyBillingPromoCreator")
  payments Payment[]
  kycAccessLogs CompanyKycAccessLog[] @relation("CompanyKycAccessActor")
  deletedKycPhotos CompanyKycRecord[] @relation("CompanyKycPhotoDeletedBy")
  sentEmailMessages EmailMessage[] @relation("EmailSender")
  targetEmailMessages EmailMessage[] @relation("EmailTargetUser")
}

model ProfileStatus {
  id          String              @id @default(cuid())
  slug        String              @unique
  title       String
  description String
  rarity      ProfileStatusRarity
  icon        String              @default("Sparkles")
  isActive    Boolean             @default(true)
  isSystem    Boolean             @default(false)
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  unlocks         UserProfileStatusUnlock[]
  selectedByUsers User[]                    @relation("SelectedProfileStatus")

  @@index([rarity, isActive])
}

model UserProfileStatusUnlock {
  id           String   @id @default(cuid())
  userId       Int
  statusId     String
  source       String   @default("MANUAL")
  unlockedById Int?
  unlockedAt   DateTime @default(now())
  seenAt       DateTime?

  user       User          @relation("UserProfileStatusUnlocks", fields: [userId], references: [id], onDelete: Cascade)
  status     ProfileStatus @relation(fields: [statusId], references: [id], onDelete: Cascade)
  unlockedBy User?         @relation("ProfileStatusUnlockedBy", fields: [unlockedById], references: [id], onDelete: SetNull)

  @@unique([userId, statusId])
  @@index([userId, seenAt])
  @@index([statusId])
  @@index([unlockedById])
}

model PlatformCounter {
  key       String   @id
  value     Int      @default(0)
  updatedAt DateTime @updatedAt
}

model AdminUserPermission {
  id        String          @id @default(cuid())
  userId    Int
  scope     PermissionScope
  canView   Boolean         @default(false)
  canEdit   Boolean         @default(false)
  canApprove Boolean        @default(false)
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, scope])
  @@index([scope])
}

model Category {
  id          Int       @id @default(autoincrement())
  slug        String    @unique
  name        String
  description String?
  icon        String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  companies      Company[]
  companyCategories CompanyCategory[]
  subscriptions  Subscription[]
  subscriptionBundles SubscriptionBundle[]
  favoredByUsers UserFavoriteCategory[]
}

model UserFavoriteCategory {
  id         Int      @id @default(autoincrement())
  userId     Int
  categoryId Int
  createdAt  DateTime @default(now())

  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@unique([userId, categoryId])
  @@index([categoryId])
}

model Company {
  id                Int       @id @default(autoincrement())
  slug              String    @unique
  name              String
  description       String?
  categoryId        Int
  pointsPerReward   Int       @default(100)
  subscriptionSpendPolicy SubscriptionSpendPolicy @default(EXCLUDE)
  platformCommissionPercent Decimal @default(12.00) @db.Decimal(5, 2)
  platformMonthlyFee Decimal @default(4990.00) @db.Decimal(10, 2)
  commissionFreeMonthlyTurnover Decimal @default(50000.00) @db.Decimal(12, 2)
  monthlyFeeOverride Decimal? @db.Decimal(10, 2)
  monthlyFeeOverrideEndsAt DateTime?
  commissionGraceEndsAt DateTime?
  isActive          Boolean   @default(true)
  operatesOnline    Boolean   @default(false)
  ownerUserId       Int?      @unique
  supportManagerId  Int?
  supportManagerAssignedAt DateTime?
  employmentType    CompanyEmploymentType?
  identityVerificationMode IdentityVerificationMode @default(FULL)
  identityVerificationCompleted Boolean @default(false)
  verificationStatus CompanyVerificationStatus @default(DRAFT)
  legalFirstName    String?
  legalMiddleName   String?
  legalLastName     String?
  birthDate         DateTime?
  legalFullName     String?
  legalInn          String?
  legalOgrnip       String?
  legalRegistrationRegion String?
  payoutBankName    String?
  payoutBik         String?
  payoutAccount     String?
  payoutCorrespondentAccount String?
  payoutCardLast4   String?
  passportVerificationStatus CompanyVerificationStatus @default(DRAFT)
  passportLast4     String?
  passportDataDeletedAt DateTime?
  verificationSubmittedAt DateTime?
  verificationReviewedAt DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  category          Category        @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  categories        CompanyCategory[]
  locations         CompanyLocation[]
  levelRules        CompanyLevelRule[]
  owner             User?           @relation("CompanyOwner", fields: [ownerUserId], references: [id], onDelete: SetNull)
  supportManager    User?           @relation("CompanySupportManager", fields: [supportManagerId], references: [id], onDelete: SetNull)
  subscriptions     Subscription[]
  subscriptionBundleParts SubscriptionBundleParticipant[]
  proposedSubscriptionBundles SubscriptionBundle[] @relation("SubscriptionBundleProposerCompany")
  promoPointCodes   PromoCode[]     @relation("PromoPointCompany")
  referralCampaigns ReferralCampaign[] @relation("ReferralBonusCompany")
  currentReferral  CompanyReferral?
  userLinks         UserCompany[]
  loyaltyTransactions LoyaltyTransaction[]
  verificationApplications CompanyVerificationApplication[]
  financeOperations FinanceOperation[]
  members           CompanyMember[]
  purchases         CompanyPurchase[]
  subscriptionRedemptions SubscriptionRedemption[]
  subscriptionBundleRedemptions SubscriptionBundleRedemption[]
  billingAccount     CompanyBillingAccount?
  billingInvoices    CompanyBillingInvoice[]
  billingPromoRedemptions CompanyBillingPromoRedemption[]
  payments           Payment[]
  kycRecord          CompanyKycRecord?
  targetEmailMessages EmailMessage[] @relation("EmailTargetCompany")

  @@index([categoryId])
  @@index([supportManagerId])
  @@index([verificationStatus, verificationSubmittedAt])
}

model CompanyBillingAccount {
  id                    String               @id @default(cuid())
  companyId             Int                  @unique
  status                CompanyBillingStatus @default(TRIAL)
  trialStartedAt        DateTime?
  trialEndsAt           DateTime?
  currentPeriodStartsAt DateTime
  currentPeriodEndsAt   DateTime
  appliedPromoCodeId    String?
  createdAt             DateTime             @default(now())
  updatedAt             DateTime             @updatedAt

  company          Company                  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  appliedPromoCode CompanyBillingPromoCode? @relation("AppliedCompanyBillingPromo", fields: [appliedPromoCodeId], references: [id], onDelete: SetNull)

  @@index([status, currentPeriodEndsAt])
  @@index([appliedPromoCodeId])
}

model CompanyBillingInvoice {
  id                       String                      @id @default(cuid())
  uuid                     String                      @unique @default(uuid())
  companyId                Int
  status                   CompanyBillingInvoiceStatus @default(OPEN)
  periodStartsAt           DateTime
  periodEndsAt             DateTime
  baseFee                  Decimal                     @db.Decimal(12, 2)
  promoDiscountPercent     Decimal                     @default(0) @db.Decimal(5, 2)
  promoDiscountAmount      Decimal                     @default(0) @db.Decimal(12, 2)
  commissionCreditAmount   Decimal                     @default(0) @db.Decimal(12, 2)
  amountDue                Decimal                     @db.Decimal(12, 2)
  paidAmount               Decimal                     @default(0) @db.Decimal(12, 2)
  paidAt                   DateTime?
  createdAt                DateTime                    @default(now())
  updatedAt                DateTime                    @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, periodStartsAt])
  @@index([companyId, status, createdAt])
  @@index([status, periodEndsAt])
}

model CompanyBillingPromoCode {
  id                 String   @id @default(cuid())
  uuid               String   @unique @default(uuid())
  code               String   @unique
  title              String
  description        String?
  discountPercent    Decimal  @db.Decimal(5, 2)
  maxRedemptions     Int?
  redemptionCount    Int      @default(0)
  startsAt           DateTime?
  expiresAt          DateTime?
  isActive           Boolean  @default(true)
  createdByUserId    Int
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  createdBy       User                          @relation("CompanyBillingPromoCreator", fields: [createdByUserId], references: [id], onDelete: Restrict)
  appliedAccounts CompanyBillingAccount[]       @relation("AppliedCompanyBillingPromo")
  redemptions     CompanyBillingPromoRedemption[]

  @@index([isActive, expiresAt])
  @@index([createdByUserId, createdAt])
}

model CompanyBillingPromoRedemption {
  id          String   @id @default(cuid())
  promoCodeId String
  companyId   Int
  redeemedAt  DateTime @default(now())

  promoCode CompanyBillingPromoCode @relation(fields: [promoCodeId], references: [id], onDelete: Cascade)
  company   Company                 @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([promoCodeId, companyId])
  @@index([companyId, redeemedAt])
}

model Payment {
  id                       Int             @id @default(autoincrement())
  uuid                     String          @unique @default(uuid())
  provider                 PaymentProvider @default(YOOKASSA)
  purpose                  PaymentPurpose
  status                   PaymentStatus   @default(PENDING)
  amount                   Decimal         @db.Decimal(12, 2)
  currency                 String          @default("RUB")
  description              String
  userId                   Int
  companyId                Int?
  subscriptionId           Int?
  subscriptionBundleId     Int?
  userSubscriptionId       Int?            @unique
  userSubscriptionBundleId Int?            @unique
  providerPaymentId        String?         @unique
  providerStatus           String?
  idempotenceKey           String          @unique
  confirmationUrl          String?
  returnUrl                String?
  paidAt                   DateTime?
  canceledAt               DateTime?
  cancelReason             String?
  metadata                 Json?
  providerPayload          Json?
  createdAt                DateTime        @default(now())
  updatedAt                DateTime        @updatedAt

  user                   User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  company                Company?                @relation(fields: [companyId], references: [id], onDelete: SetNull)
  subscription           Subscription?           @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)
  subscriptionBundle     SubscriptionBundle?     @relation(fields: [subscriptionBundleId], references: [id], onDelete: SetNull)
  userSubscription       UserSubscription?       @relation(fields: [userSubscriptionId], references: [id], onDelete: SetNull)
  userSubscriptionBundle UserSubscriptionBundle? @relation(fields: [userSubscriptionBundleId], references: [id], onDelete: SetNull)

  @@index([userId, status, createdAt])
  @@index([companyId, status, createdAt])
  @@index([purpose, status])
  @@index([provider, status])
  @@index([createdAt])
}

model CompanyReferral {
  id              Int                   @id @default(autoincrement())
  uuid            String                @unique @default(uuid())
  companyId       Int                   @unique
  referrerUserId  Int
  status          CompanyReferralStatus @default(ACTIVE)
  pipelineStatus  CompanyReferralPipelineStatus @default(CONNECTED)
  referralPercent Decimal               @default(1.00) @db.Decimal(5, 2)
  source          String                @default("PR")
  notes           String?               @db.Text
  startedAt       DateTime              @default(now())
  endedAt         DateTime?
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt

  company         Company               @relation(fields: [companyId], references: [id], onDelete: Cascade)
  referrer        User                  @relation("CompanyReferralOwner", fields: [referrerUserId], references: [id], onDelete: Restrict)

  @@index([referrerUserId, status])
  @@index([pipelineStatus])
  @@index([status, startedAt])
}

model CompanyVerificationApplication {
  id                Int                       @id @default(autoincrement())
  uuid              String                    @unique @default(uuid())
  companyId         Int?
  employmentType    CompanyEmploymentType
  identityVerificationMode IdentityVerificationMode @default(FULL)
  status            CompanyVerificationStatus @default(SUBMITTED)
  contactName       String
  contactEmail      String
  contactTelegram   String?
  companyName       String
  businessCategory  String
  legalFirstName    String?
  legalMiddleName   String?
  legalLastName     String?
  birthDate         DateTime?
  legalFullName     String
  legalInn          String
  legalOgrnip       String?
  legalRegistrationRegion String?
  payoutBankName    String?
  payoutBik         String?
  payoutAccount     String?
  payoutCorrespondentAccount String?
  payoutCardLast4   String?
  passportEncryptedPayload String?
  passportEncryptionIv String?
  passportEncryptionTag String?
  passportLast4     String?
  verificationDeferralReason String?
  passportDataDeletedAt DateTime?
  consentAcceptedAt DateTime
  ipAddress         String?
  userAgent         String?
  adminNotifiedAt   DateTime?
  createdAt         DateTime                  @default(now())
  updatedAt         DateTime                  @updatedAt

  company           Company?                  @relation(fields: [companyId], references: [id], onDelete: SetNull)
  passportFiles     PassportVerificationFile[]
  kycRecord         CompanyKycRecord?

  @@index([status, createdAt])
  @@index([contactEmail])
  @@index([legalInn])
}

model CompanyKycRecord {
  id                       Int                       @id @default(autoincrement())
  uuid                     String                    @unique @default(uuid())
  companyId                Int                       @unique
  applicationId            Int?                      @unique
  status                   CompanyVerificationStatus @default(APPROVED)
  employmentType           CompanyEmploymentType?
  identityVerificationMode IdentityVerificationMode   @default(FULL)
  legalFirstName           String?
  legalMiddleName          String?
  legalLastName            String?
  birthDate                DateTime?
  legalFullName            String?
  legalInn                 String?
  legalOgrnip              String?
  legalRegistrationRegion  String?
  passportEncryptedPayload String?
  passportEncryptionIv     String?
  passportEncryptionTag    String?
  passportLast4            String?
  passportPhotoEncrypted   Bytes?
  passportPhotoEncryptionIv String?
  passportPhotoEncryptionTag String?
  passportPhotoMimeType    String?
  passportPhotoOriginalName String?
  passportPhotoSize        Int?
  passportPhotoSha256      String?
  passportPhotoDeletedAt   DateTime?
  passportPhotoDeletedById Int?
  createdAt                DateTime                  @default(now())
  updatedAt                DateTime                  @updatedAt

  company                  Company                   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  application              CompanyVerificationApplication? @relation(fields: [applicationId], references: [id], onDelete: SetNull)
  passportPhotoDeletedBy   User?                     @relation("CompanyKycPhotoDeletedBy", fields: [passportPhotoDeletedById], references: [id], onDelete: SetNull)
  accessLogs               CompanyKycAccessLog[]

  @@index([status, updatedAt])
}

model CompanyKycAccessLog {
  id          Int                    @id @default(autoincrement())
  uuid        String                 @unique @default(uuid())
  kycRecordId Int
  actorUserId Int?
  action      CompanyKycAccessAction
  reason      String?
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime              @default(now())

  kycRecord   CompanyKycRecord      @relation(fields: [kycRecordId], references: [id], onDelete: Cascade)
  actor       User?                  @relation("CompanyKycAccessActor", fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([kycRecordId, createdAt])
  @@index([actorUserId, createdAt])
}

model PassportVerificationFile {
  id             Int                @id @default(autoincrement())
  uuid           String             @unique @default(uuid())
  applicationId  Int
  storageKey     String             @unique
  originalName   String?
  mimeType       String
  size           Int
  sha256         String
  encryptionIv   String
  encryptionTag  String
  status         PassportFileStatus @default(ACTIVE)
  uploadedAt     DateTime           @default(now())
  deletedAt      DateTime?
  missingAt      DateTime?

  application CompanyVerificationApplication @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@index([applicationId, status])
  @@index([status, uploadedAt])
}

model FinanceOperation {
  id             String                 @id @default(cuid())
  uuid           String                 @unique @default(uuid())
  type           FinanceOperationType
  status         FinanceOperationStatus @default(DRAFT)
  amount         Decimal                @db.Decimal(12, 2)
  currency       String                 @default("RUB")
  companyId      Int?
  title          String
  details        String?                @db.Text
  requestedById  Int?
  approvedById   Int?
  requestedAt    DateTime?
  approvedAt     DateTime?
  processedAt    DateTime?
  createdAt      DateTime               @default(now())
  updatedAt      DateTime               @updatedAt

  company     Company? @relation(fields: [companyId], references: [id], onDelete: SetNull)
  requestedBy User?    @relation("FinanceRequestedBy", fields: [requestedById], references: [id], onDelete: SetNull)
  approvedBy  User?    @relation("FinanceApprovedBy", fields: [approvedById], references: [id], onDelete: SetNull)

  @@index([status, createdAt])
  @@index([companyId, createdAt])
  @@index([requestedById, createdAt])
}

model TelegramLinkToken {
  id          String    @id @default(cuid())
  token       String    @unique
  userId      Int
  expiresAt   DateTime
  usedAt      DateTime?
  createdAt   DateTime  @default(now())

  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
}

model CustomerLookupCode {
  id        String    @id @default(cuid())
  codeHash  String    @unique
  userId    Int
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
  @@index([expiresAt, usedAt])
}

model Subscription {
  id             Int       @id @default(autoincrement())
  uuid           String    @unique @default(uuid())
  slug           String    @unique
  name           String
  description    String
  price          Decimal   @db.Decimal(10, 2)
  renewalPeriod  String
  renewalValue   Int       @default(1)
  renewalUnit    String    @default("month")
  promoBonusDays Int       @default(0)
  promoEndsAt    DateTime?
  isActive       Boolean   @default(true)
  companyId      Int?
  categoryId     Int?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  company        Company?          @relation(fields: [companyId], references: [id], onDelete: SetNull)
  category       Category?         @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  userPlans      UserSubscription[]
  promoCodes     PromoCode[]
  entitlements   SubscriptionEntitlement[]
  payments       Payment[]

  @@index([companyId])
  @@index([categoryId])
}

model SubscriptionBundle {
  id             Int                      @id @default(autoincrement())
  uuid           String                   @unique @default(uuid())
  slug           String                   @unique
  name           String
  description    String                   @db.Text
  price          Decimal                  @db.Decimal(10, 2)
  renewalPeriod  String
  renewalValue   Int                      @default(1)
  renewalUnit    String                   @default("month")
  promoBonusDays Int                      @default(0)
  status         SubscriptionBundleStatus @default(DRAFT)
  isActive       Boolean                  @default(false)
  categoryId     Int?
  proposedByCompanyId Int?
  proposedByUserId Int?
  activatedAt    DateTime?
  createdAt      DateTime                 @default(now())
  updatedAt      DateTime                 @updatedAt

  category       Category?                @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  proposedByCompany Company?              @relation("SubscriptionBundleProposerCompany", fields: [proposedByCompanyId], references: [id], onDelete: SetNull)
  proposedByUser User?                    @relation("SubscriptionBundleProposer", fields: [proposedByUserId], references: [id], onDelete: SetNull)
  participants   SubscriptionBundleParticipant[]
  userBundles    UserSubscriptionBundle[]
  payments       Payment[]

  @@index([status, isActive])
  @@index([categoryId])
  @@index([proposedByCompanyId])
}

model SubscriptionBundleParticipant {
  id                  Int                @id @default(autoincrement())
  uuid                String             @unique @default(uuid())
  bundleId            Int
  companyId           Int
  benefitTitle        String
  benefitDescription  String             @db.Text
  fulfillmentNote     String?            @db.Text
  revenueSharePercent Decimal            @db.Decimal(5, 2)
  allowance           Int                @default(1)
  windowValue         Int                @default(1)
  windowUnit          SubscriptionEntitlementWindow @default(MONTH)
  approvalStatus      SubscriptionBundleParticipantStatus @default(APPROVED)
  approvedAt          DateTime?
  rejectedAt          DateTime?
  approvedById        Int?
  sortOrder           Int                @default(1)
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt

  bundle              SubscriptionBundle @relation(fields: [bundleId], references: [id], onDelete: Cascade)
  company             Company            @relation(fields: [companyId], references: [id], onDelete: Cascade)
  approvedBy          User?              @relation("SubscriptionBundleParticipantApprover", fields: [approvedById], references: [id], onDelete: SetNull)
  redemptions         SubscriptionBundleRedemption[]

  @@unique([bundleId, companyId])
  @@index([companyId])
  @@index([approvalStatus])
}

model UserSubscriptionBundle {
  id             Int                @id @default(autoincrement())
  uuid           String             @unique @default(uuid())
  userId         Int
  bundleId       Int
  status         SubscriptionStatus @default(ACTIVE)
  activatedAt    DateTime           @default(now())
  expiresAt      DateTime?
  willAutoRenew  Boolean            @default(true)
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  user           User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  bundle         SubscriptionBundle @relation(fields: [bundleId], references: [id], onDelete: Cascade)
  redemptions    SubscriptionBundleRedemption[]
  payment        Payment?

  @@index([userId, status])
  @@index([bundleId])
}

model CompanyLocation {
  id               Int      @id @default(autoincrement())
  uuid             String   @unique @default(uuid())
  companyId        Int
  title            String?
  address          String
  city             String?
  latitude         Decimal  @db.Decimal(10, 7)
  longitude        Decimal  @db.Decimal(10, 7)
  precision        String?
  geocoderResponse Json?
  openTime         String   @default("09:00")
  closeTime        String   @default("21:00")
  workingDays      Int[]    @default([0, 1, 2, 3, 4, 5, 6])
  isMain           Boolean  @default(false)
  isActive         Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  company          Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId, isActive])
}

model CompanyCategory {
  id         Int      @id @default(autoincrement())
  companyId  Int
  categoryId Int
  createdAt  DateTime @default(now())

  company    Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@unique([companyId, categoryId])
  @@index([categoryId])
}

model CompanyLevelRule {
  id              Int      @id @default(autoincrement())
  companyId       Int
  levelName       String
  minTotalSpend   Decimal  @db.Decimal(12, 2)
  cashbackPercent Decimal  @db.Decimal(5, 2)
  sortOrder       Int
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  company         Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId, sortOrder])
  @@unique([companyId, sortOrder])
}

model CompanyMember {
  id        Int               @id @default(autoincrement())
  uuid      String            @unique @default(uuid())
  companyId Int
  userId    Int
  role      CompanyMemberRole @default(CASHIER)
  isActive  Boolean           @default(true)
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([companyId, userId])
  @@index([userId, isActive])
  @@index([companyId, role, isActive])
}

model CompanyPurchase {
  id              Int      @id @default(autoincrement())
  uuid            String   @unique @default(uuid())
  companyId       Int
  userId          Int
  processedById   Int
  amount          Decimal  @db.Decimal(12, 2)
  cashbackPercent Decimal  @db.Decimal(5, 2)
  pointsAwarded   Int
  description     String?
  createdAt       DateTime @default(now())

  company     Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user        User    @relation("CompanyPurchaseCustomer", fields: [userId], references: [id], onDelete: Cascade)
  processedBy User    @relation("CompanyPurchaseProcessor", fields: [processedById], references: [id], onDelete: Restrict)

  @@index([companyId, userId, createdAt])
  @@index([processedById, createdAt])
}

model UserCompany {
  id               Int       @id @default(autoincrement())
  userId           Int
  companyId        Int
  balance          Int       @default(0)
  pointsToNextReward Int?
  expiringPoints   Int?
  expiringDate     DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  company          Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([userId, companyId])
  @@index([companyId])
}

model UserSubscription {
  id             Int                @id @default(autoincrement())
  userId         Int
  subscriptionId Int
  status         SubscriptionStatus @default(ACTIVE)
  activatedAt    DateTime           @default(now())
  expiresAt      DateTime?
  willAutoRenew  Boolean            @default(true)
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  subscription   Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  redemptions    SubscriptionRedemption[]
  payment        Payment?

  @@index([userId, status])
  @@index([subscriptionId])
}

model SubscriptionEntitlement {
  id             Int                           @id @default(autoincrement())
  uuid           String                        @unique @default(uuid())
  subscriptionId Int
  title          String
  description    String?
  allowance      Int                           @default(1)
  windowValue    Int                           @default(1)
  windowUnit     SubscriptionEntitlementWindow @default(MONTH)
  isActive       Boolean                       @default(true)
  createdAt      DateTime                      @default(now())
  updatedAt      DateTime                      @updatedAt

  subscription Subscription             @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  redemptions  SubscriptionRedemption[]

  @@index([subscriptionId, isActive])
}

model SubscriptionRedemption {
  id                 Int      @id @default(autoincrement())
  uuid               String   @unique @default(uuid())
  userSubscriptionId Int
  entitlementId      Int
  companyId          Int
  processedById      Int
  quantity           Int      @default(1)
  note               String?
  redeemedAt         DateTime @default(now())

  userSubscription UserSubscription       @relation(fields: [userSubscriptionId], references: [id], onDelete: Cascade)
  entitlement      SubscriptionEntitlement @relation(fields: [entitlementId], references: [id], onDelete: Cascade)
  company          Company                @relation(fields: [companyId], references: [id], onDelete: Cascade)
  processedBy      User                   @relation("SubscriptionRedemptionProcessor", fields: [processedById], references: [id], onDelete: Restrict)

  @@index([userSubscriptionId, entitlementId, redeemedAt])
  @@index([companyId, redeemedAt])
  @@index([processedById, redeemedAt])
}

model SubscriptionBundleRedemption {
  id                       Int      @id @default(autoincrement())
  uuid                     String   @unique @default(uuid())
  userSubscriptionBundleId Int
  participantId            Int
  companyId                Int
  processedById            Int
  quantity                 Int      @default(1)
  note                     String?
  redeemedAt               DateTime @default(now())

  userSubscriptionBundle UserSubscriptionBundle       @relation(fields: [userSubscriptionBundleId], references: [id], onDelete: Cascade)
  participant            SubscriptionBundleParticipant @relation(fields: [participantId], references: [id], onDelete: Cascade)
  company                Company                      @relation(fields: [companyId], references: [id], onDelete: Cascade)
  processedBy            User                         @relation("SubscriptionBundleRedemptionProcessor", fields: [processedById], references: [id], onDelete: Restrict)

  @@index([userSubscriptionBundleId, participantId, redeemedAt])
  @@index([companyId, redeemedAt])
  @@index([processedById, redeemedAt])
}

model UserProfilePreference {
  id                    Int      @id @default(autoincrement())
  userId                Int      @unique
  onboardingCompletedAt DateTime?
  onboardingSkippedAt   DateTime?
  geolocationPromptedAt DateTime?
  profileVisibility     String   @default("PRIVATE")
  preferredLocale       String   @default("en")
  marketingOptIn        Boolean  @default(false)
  showActivityStats     Boolean  @default(true)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  user                  User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model PromoCode {
  id             Int                 @id @default(autoincrement())
  code           String              @unique
  title          String
  description    String?
  rewardType     PromoCodeRewardType
  points         Int                 @default(0)
  companyId      Int?
  subscriptionId Int?
  maxRedemptions Int?
  expiresAt      DateTime?
  isActive       Boolean             @default(true)
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt

  company        Company?            @relation("PromoPointCompany", fields: [companyId], references: [id], onDelete: SetNull)
  subscription   Subscription?       @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)
  redemptions    PromoCodeRedemption[]
}

model PromoCodeRedemption {
  id          Int       @id @default(autoincrement())
  promoCodeId Int
  userId      Int
  redeemedAt  DateTime  @default(now())

  promoCode   PromoCode @relation(fields: [promoCodeId], references: [id], onDelete: Cascade)
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([promoCodeId, userId])
  @@index([userId])
}

model ReferralCampaign {
  id                 Int      @id @default(autoincrement())
  title              String   @default("Invite a friend")
  inviterBonusPoints Int      @default(250)
  invitedBonusPoints Int      @default(250)
  bonusCompanyId     Int?
  isActive           Boolean  @default(true)
  updatedAt          DateTime @updatedAt
  createdAt          DateTime @default(now())

  bonusCompany       Company? @relation("ReferralBonusCompany", fields: [bonusCompanyId], references: [id], onDelete: SetNull)
}

model ReferralInvite {
  id            Int                  @id @default(autoincrement())
  code          String               @unique
  inviterUserId Int
  invitedUserId Int?                 @unique
  status        ReferralInviteStatus @default(CREATED)
  rewardedAt    DateTime?
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt

  inviter       User                 @relation("ReferralInviter", fields: [inviterUserId], references: [id], onDelete: Cascade)
  invited       User?                @relation("ReferralInvited", fields: [invitedUserId], references: [id], onDelete: SetNull)

  @@index([inviterUserId])
}

/// Rotating refresh tokens for JWT sessions (Passport/JWT strategy).
model RefreshToken {
  id        String    @id @default(cuid())
  tokenHash String
  userId    Int
  expiresAt DateTime
  createdAt DateTime  @default(now())
  revokedAt DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

/// OAuth 2.0 provider linkage (groundwork for future OAuth / OpenID Connect).
model OAuthAccount {
  id                  String    @id @default(cuid())
  provider            String
  providerAccountId   String
  userId              Int
  accessToken         String?   @db.Text
  refreshToken        String?   @db.Text
  expiresAt           DateTime?
  scope               String?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model LoginEvent {
  id           String   @id @default(cuid())
  userId       Int
  ipAddress    String?
  countryCode  String?
  city         String?
  userAgent    String?
  deviceLabel  String?
  requestId    String?
  createdAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

model LoyaltyTransaction {
  id          Int                      @id @default(autoincrement())
  uuid        String                   @unique @default(uuid())
  userId      Int
  companyId   Int
  type        LoyaltyTransactionType
  status      LoyaltyTransactionStatus @default(ACTIVE)
  amount      Int
  description String?
  occurredAt  DateTime                 @default(now())
  createdAt   DateTime                 @default(now())
  updatedAt   DateTime                 @updatedAt

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([userId, occurredAt])
  @@index([companyId, occurredAt])
}

/// Email change workflow initiated by admin and confirmed by end user via secure token link.
model EmailChangeRequest {
  id                String   @id @default(cuid())
  tokenHash         String   @unique
  userId            Int
  requestedByUserId Int
  oldEmail          String
  newEmail          String
  expiresAt         DateTime
  createdAt         DateTime @default(now())
  usedAt            DateTime?
  revokedAt         DateTime?

  user        User @relation("EmailChangeTarget", fields: [userId], references: [id], onDelete: Cascade)
  requestedBy User @relation("EmailChangeRequester", fields: [requestedByUserId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([requestedByUserId])
  @@index([expiresAt])
}

model EmailMessage {
  id              String                 @id @default(cuid())
  uuid            String                 @unique @default(uuid())
  targetType      EmailMessageTargetType @default(DIRECT)
  toEmail         String
  toName          String?
  subject         String
  bodyText        String                 @db.Text
  bodyHtml        String?                @db.Text
  status          EmailMessageStatus     @default(PENDING)
  provider        String?
  error           String?                @db.Text
  sentByUserId    Int?
  targetUserId    Int?
  targetCompanyId Int?
  createdAt       DateTime               @default(now())
  sentAt          DateTime?
  updatedAt       DateTime               @updatedAt

  sentBy        User?    @relation("EmailSender", fields: [sentByUserId], references: [id], onDelete: SetNull)
  targetUser    User?    @relation("EmailTargetUser", fields: [targetUserId], references: [id], onDelete: SetNull)
  targetCompany Company? @relation("EmailTargetCompany", fields: [targetCompanyId], references: [id], onDelete: SetNull)

  @@index([status, createdAt])
  @@index([toEmail])
  @@index([sentByUserId, createdAt])
  @@index([targetUserId, createdAt])
  @@index([targetCompanyId, createdAt])
}

model EmailVerificationCode {
  id              String                  @id @default(cuid())
  email           String
  normalizedEmail String
  name            String
  passwordHash    String
  role            UserRole                @default(CLIENT)
  codeHash        String
  purpose         EmailVerificationPurpose @default(REGISTRATION)
  status          EmailVerificationStatus @default(PENDING)
  attempts        Int                     @default(0)
  expiresAt       DateTime
  consumedAt      DateTime?
  createdAt       DateTime                @default(now())
  updatedAt       DateTime                @updatedAt

  @@index([normalizedEmail, status, expiresAt])
  @@index([expiresAt])
}

model AuditEvent {
  id          String         @id @default(cuid())
  workspace   AuditWorkspace @default(MANAGER)
  level       AuditLevel     @default(INFO)
  category    AuditCategory
  action      String
  details     String?
  actorUserId Int?
  actorLabel  String
  targetUserId Int?
  targetLabel String?
  targetEmail String?
  targetUuid  String?
  result      AuditResult    @default(SUCCESS)
  tags        String[]       @default([])
  ipAddress   String?
  countryCode String?
  linkUrl     String?
  linkLabel   String?
  createdAt   DateTime       @default(now())

  actorUser   User? @relation("AuditActor", fields: [actorUserId], references: [id], onDelete: SetNull)
  targetUser  User? @relation("AuditTarget", fields: [targetUserId], references: [id], onDelete: SetNull)

  @@index([workspace, createdAt])
  @@index([category, createdAt])
  @@index([level, createdAt])
  @@index([targetUserId, createdAt])
  @@index([targetEmail])
  @@index([targetUuid])
}

model AdminTask {
  id           String            @id @default(cuid())
  uuid         String            @unique @default(uuid())
  source       AdminTaskSource
  sourceKey    String            @unique
  title        String
  description  String?           @db.Text
  priority     AdminTaskPriority @default(NORMAL)
  status       AdminTaskStatus   @default(OPEN)
  targetUrl    String?
  targetLabel  String?
  assignedToId Int?
  resolvedById Int?
  assignedAt   DateTime?
  resolvedAt   DateTime?
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  assignedTo User? @relation("AdminTaskAssignee", fields: [assignedToId], references: [id], onDelete: SetNull)
  resolvedBy User? @relation("AdminTaskResolver", fields: [resolvedById], references: [id], onDelete: SetNull)

  @@index([status, priority, createdAt])
  @@index([source, status, createdAt])
  @@index([assignedToId, status])
}

model LandingLead {
  id                Int       @id @default(autoincrement())
  uuid              String    @unique @default(uuid())
  name              String
  company           String?
  contact           String
  business          String?
  message           String   @db.Text
  status            LandingLeadStatus @default(NEW)
  source            String   @default("landing")
  ipAddress         String?
  userAgent         String?
  fingerprint       String
  spamScore         Int      @default(0)
  notes             String?  @db.Text
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  processedAt       DateTime?

  deliveries        NotificationDelivery[]

  @@index([status, createdAt])
  @@index([contact])
  @@index([fingerprint, createdAt])
}

model NotificationDelivery {
  id             String   @id @default(cuid())
  leadId         Int
  channel        String   @default("telegram")
  recipientRole  String
  recipientChatId String
  recipientLabel String?
  status         NotificationDeliveryStatus @default(PENDING)
  attempts       Int      @default(0)
  telegramMessageId Int?
  lastError      String?  @db.Text
  nextRetryAt    DateTime?
  sentAt         DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  lead           LandingLead @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@index([leadId])
  @@index([status, nextRetryAt])
  @@index([recipientRole, createdAt])
}

model TelegramMessageQueue {
  id                String   @id @default(cuid())
  recipientChatId   String
  recipientRole     String?
  recipientLabel    String?
  text              String   @db.Text
  parseMode         String?
  replyMarkup       Json?
  status            NotificationDeliveryStatus @default(PENDING)
  attempts          Int      @default(0)
  telegramMessageId Int?
  lastError         String?  @db.Text
  nextRetryAt       DateTime?
  sentAt            DateTime?
  source            String?
  sourceId          String?
  priority          Int      @default(0)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([status, nextRetryAt])
  @@index([source, sourceId])
  @@index([recipientChatId, createdAt])
}
